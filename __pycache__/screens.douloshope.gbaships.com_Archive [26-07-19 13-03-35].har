            "size": 1639,
            "text": "<svg xmlns=\"http://www.w3.org/2000/svg\" viewBox=\"0 0 1040 360\" width=\"1040\" height=\"360\" role=\"img\" aria-label=\"StreetSign (dark mode)\">\n  <defs>\n    <linearGradient id=\"bg2\" x1=\"0\" y1=\"0\" x2=\"0\" y2=\"1\">\n      <stop offset=\"0\" stop-color=\"#1E293B\"/>\n      <stop offset=\"1\" stop-color=\"#0F172A\"/>\n    </linearGradient>\n    <linearGradient id=\"scr2\" x1=\"0\" y1=\"0\" x2=\"1\" y2=\"1\">\n      <stop offset=\"0\" stop-color=\"#334155\"/>\n      <stop offset=\"1\" stop-color=\"#1E293B\"/>\n    </linearGradient>\n    <linearGradient id=\"ess2\" x1=\"0\" y1=\"0\" x2=\"1\" y2=\"1\">\n      <stop offset=\"0\" stop-color=\"#38BDF8\"/>\n      <stop offset=\"1\" stop-color=\"#0284C7\"/>\n    </linearGradient>\n  </defs>\n\n  <!-- icon scaled to 280px, vertically centered (y 40–320) -->\n  <g transform=\"translate(36,40) scale(0.546875)\">\n    <rect width=\"512\" height=\"512\" rx=\"104\" fill=\"url(#bg2)\"/>\n    <rect x=\"242\" y=\"300\" width=\"28\" height=\"62\" fill=\"#020617\"/>\n    <rect x=\"182\" y=\"356\" width=\"148\" height=\"24\" rx=\"12\" fill=\"#020617\"/>\n    <rect x=\"92\" y=\"84\" width=\"328\" height=\"224\" rx=\"30\" fill=\"#020617\"/>\n    <rect x=\"116\" y=\"108\" width=\"280\" height=\"176\" rx=\"18\" fill=\"url(#scr2)\"/>\n    <path d=\"M302 163 A46 33 0 1 0 256 196 A46 33 0 1 1 210 229\"\n          fill=\"none\" stroke=\"url(#ess2)\" stroke-width=\"28\" stroke-linecap=\"round\" stroke-linejoin=\"round\"/>\n  </g>\n\n  <!-- wordmark, baseline tuned to icon center -->\n  <text x=\"360\" y=\"222\" font-family=\"system-ui, -apple-system, 'Segoe UI', Roboto, Arial, sans-serif\"\n        font-size=\"116\" font-weight=\"800\" letter-spacing=\"-3\">\n    <tspan fill=\"#F8FAFC\">Street</tspan><tspan fill=\"#38BDF8\">Sign</tspan>\n  </text>\n</svg>\n"
