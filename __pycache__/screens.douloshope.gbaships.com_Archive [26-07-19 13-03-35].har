e-responsive\">\n\t\t<table class=\"table table-striped\">\n\t\t<thead>\n\t\t\t<tr>\n\t\t\t\t<th scope=\"col\">Access Key / Client ID</th>\n\t\t\t\t<th scope=\"col\">Layout &amp; Engine</th>\n\t\t\t\t<th scope=\"col\">Display Options</th>\n\t\t\t\t<th scope=\"col\"></th>\n\t\t\t</tr>\n\t\t</thead>\n\t\t<tbody>\n\t\t\t<template x-for=\"(alias, idx) in aliases\" :key=\"idx\">\n\t\t\t<tr>\n\t\t\t\t<td>\n\t\t\t\t\t\t<input x-model=\"alias.name\" class=\"form-control\"\n\t\t\t\t       @input=\"sanitizeAliasName(alias)\"\n\t\t\t\t       title=\"Letters, numbers, hyphens and underscores only\" /><br/>\n\t\t\t\t\t\tURL: <a :href=\"urlFor(alias)\" x-text=\"'/client/' + alias.name\">URL</a><br/>\n\t\t\t\t\t\t\n\t\t\t\t\t\t\t<label>\n\t\t\t\t\t\t\tDisplay on public dashboard:\n\t\t\t\t\t\t\t<input type=checkbox x-model=\"alias.show_on_dashboard\" />\n\t\t\t\t\t\t\t</label>\n\t\t\t\t\t\t\n\t\t\t\t</td>\n\t\t\t\t<td>\n\t\t\t\t\t\n\t\t\t\t\t\t<label>Layout:\n\t\t\t\t\t\t\t<select class=\"form-control\" x-model=\"alias.screen_name\"\n\t\t\t\t\t\t\t        :class=\"{'is-invalid': !screenExists(alias)}\">\n\t\t\t\t\t\t\t\t<template x-for=\"name in screenNames\" :key=\"name\">\n\t\t\t\t\t\t\t\t\t<option :value=\"name\" x-text=\"name\"></option>\n\t\t\t\t\t\t\t\t</template>\n\t\t\t\t\t\t\t</select>\n\t\t\t\t\t\t\t<small x-show=\"!screenExists(alias)\" class=\"text-danger\">\n\t\t\t\t\t\t\t\tThis layout no longer exists\n\t\t\t\t\t\t\t</small>\n\t\t\t\t\t\t</label><br/>\n\t\t\t\t\t\t<label>Engine:\n\t\t\t\t\t\t\t<select class=\"form-control\" x-model=\"alias.screen_type\">\n\t\t\t\t\t\t\t\t<template x-for=\"st in screenTypes\" :key=\"st.engine\">\n\t\t\t\t\t\t\t\t\t<option :value=\"st.engine\" x-text=\"st.name\"></option>\n\t\t\t\t\t\t\t\t</template>\n\t\t\t\t\t\t\t</select>\n\t\t\t\t\t\t</label>\n\t\t\t\t\t\n\t\t\t\t</td>\n\t\t\t\t<td>\n\t\t\t\t\t<small>\n\t\t\t\t\t<label>fadetime:\n\t\t\t\t\t\t<input type=\"number\" class=\"form-control\" x-model=\"alias.fadetime\" />\n\t\t\t\t\t</label><br/>\n\t\t\t\t\t<label>scrollspeed:\n\t\t\t\t\t\t<input type=\"number\" class=\"form-control\" x-model=\"alias.scrollspeed\" />\n\t\t\t\t\t</label><br/>\n\t\t\t\t\t<label>aspect ratio:\n\t\t\t\t\t\t<input type=\"number\" class=\"form-control\" x-model=\"alias.forceaspect\" />\n\t\t\t\t\t</label><br/>\n\t\t\t\t\t<label>vertical offset:\n\t\t\t\t\t\t<input type=\"number\" class=\"form-control\" x-model=\"alias.forcetop\" />\n\t\t\t\t\t</label><br/>\n\t\t\t\t\t</small>\n\t\t\t\t</td>\n\t\t\t\t<td>\n\t\t\t\t\t\n\t\t\t\t\t\t <button class=\"btn btn-close\" x-on:click=\"deleteAlias(idx)\"></button>\n\t\t\t\t\t\n\t\t\t\t</td>\n\t\t\t</tr>\n\t\t\t</template>\n\t\t</tbody>\n\t\t</table>\n\t\t</div>\n\t\t</div>\n\t\n\n\t\n\t\t<div class=\"clearfix\"></div>\n\t\t\n\t\t<footer>\n\t\t\tStreetSign v1.3.3 &copy; 2013-2026 Daniel Fairhead. Forked by <a href=\"https://github.com/jamswat\">jamswat</a>.\n\t\t\t<a href=\"https://jamswat.github.io/streetsign/\">Documentation</a> ·\n\t\t\t<a href=\"https://github.com/jamswat/streetsign\">GitHub</a>\n\t\t</footer>\n\t\t\n\t</main>\n\n\t<div class=\"toast-container position-fixed bottom-0 end-0 p-3\" aria-live=\"polite\" aria-atomic=\"true\">\n\t</div>\n\n\t\n\t\n\n\t\n\n\t<div id=\"login_box\" class=\"modal fade\" data-bs-backdrop=\"static\" data-bs-keyboard=\"false\">\n\t\t<div class=\"modal-dialog\">\n\t\t\t<div class=\"modal-content\">\n\t\t\t<form action=\"/login\" method=\"POST\" novalidate class=\"needs-validation\">\n\t\t\t\t<div class=\"modal-header\">\n\t\t\t\t\t<h2>Log In</h2>\n\t\t\t\t</div>\n\t\t\t\t<div class=\"modal-body\" role=\"form\">\n\t\t\t\t\t<div class=\"row mb-3\">\n\t\t\t\t\t\t<label class=\"col-sm-2 col-form-label\" for=\"username\">Name:</label>\n\t\t\t\t\t\t<div class=\"col-sm-10\">\n\t\t\t\t\t\t\t<input id=\"username\" name=\"username\" placeholder=\"Your user name...\" class=\"form-control\" required />\n\t\t\t\t\t\t</div>\n\t\t\t\t\t</div>\n\t\t\t\t\t<div class=\"row mb-3\">\n\t\t\t\t\t\t<label class=\"col-sm-2 col-form-label\" for=\"password\">Password:</label>\n\t\t\t\t\t\t<div class=\"col-sm-10\">\n\t\t\t\t\t\t\t<input id=\"password\" name=\"password\" type=\"password\" placeholder=\"password\" class=\"form-control\" required /><br />\n\t\t\t\t\t\t\t\t<input type=\"hidden\" name=\"from\" value=\"screens\" />\n\t\t\t\t\t\t\t</div>\n\t\t\t\t\t\t</div>\n\t\t\t\t\t</div>\n\t\t\t\t\t<div class=\"modal-footer\">\n\t\t\t\t\t\t<input class=\"btn btn-primary\" type=\"submit\" value=\"Log in\" />\n\t\t\t\t\t</div>\n\t\t\t\t</form>\n\t\t\t</div>\n\t\t</div>\n\t</div>\n\n\t\n\t<div id=\"new-feed-modal\" class=\"modal fade\" tabindex=\"-1\">\n\t\t<div class=\"modal-dialog\">\n\t\t\t<div class=\"modal-content\">\n\t\t\t\t<form action=\"/feeds/\" method=\"POST\" novalidate class=\"needs-validation\">\n\t\t\t\t\t<div class=\"modal-header\">\n\t\t\t\t\t\t<h2 class=\"modal-title\">New Feed</h2>\n\t\t\t\t\t\t<button type=\"button\" class=\"btn-close\" data-bs-dismiss=\"modal\" aria-label=\"Close\"></button>\n\t\t\t\t\t</div>\n\t\t\t\t\t<div class=\"modal-body\">\n\t\t\t\t\t\t<label class=\"form-label\" for=\"new-feed-name\">Feed Name:</label>\n\t\t\t\t\t\t<input id=\"new-feed-name\" name=\"title\" class=\"form-control\" placeholder=\"Enter feed name...\" required autofocus>\n\t\t\t\t\t</div>\n\t\t\t\t\t<div class=\"modal-footer\">\n\t\t\t\t\t\t<button type=\"button\" class=\"btn btn-secondary\" data-bs-dismiss=\"modal\">Cancel</button>\n\t\t\t\t\t\t<button type=\"submit\" class=\"btn btn-primary\">Create Feed</button>\n\t\t\t\t\t</div>\n\t\t\t\t</form>\n\t\t\t</div>\n\t\t</div>\n\t</div>\n\n\t<div id=\"new-group-modal\" class=\"modal fade\" tabindex=\"-1\">\n\t\t<div class=\"modal-dialog\">\n\t\t\t<div class=\"modal-content\">\n\t\t\t<form action=\"/users_and_groups\" method=\"POST\" novalidate class=\"needs-validation\">\n\t\t\t\t<input type=\"hidden\" name=\"action\" value=\"creategroup\" />\n\t\t\t\t\t<div class=\"modal-header\">\n\t\t\t\t\t\t<h2 class=\"modal-title\">New Group<