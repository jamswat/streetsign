            "mimeType": "text/css; charset=utf-8",
            "size": 7015,
            "text": ":root {\n    --color-admin-option: #224;\n    --color-option-checked: #222;\n    --color-footer-bg: #eee;\n    --color-footer-text: #666;\n    --color-footer-link: #444;\n    --color-freespace-border: #ddd;\n    --color-fake-screen-bg: black;\n    --color-fake-screen-border: #eee;\n    --color-fake-zone-border: white;\n    --color-fake-zone-selected-bg: rgba(100,100,100,0.5);\n    --color-time-future: #349;\n    --color-time-now-bg: #bcd;\n    --color-time-now-alt-bg: #abc;\n    --color-time-past: #914;\n    --sidebar-width: 250px;\n    --sidebar-bg: #212529;\n    --sidebar-text: #adb5bd;\n    --sidebar-active-bg: rgba(255,255,255,0.1);\n    --sidebar-hover-bg: rgba(255,255,255,0.05);\n}\n\nbody {\n    display: flex;\n    min-height: 100vh;\n}\n\n.sidebar {\n    position: fixed;\n    top: 0;\n    left: 0;\n    bottom: 0;\n    width: var(--sidebar-width);\n    background: var(--sidebar-bg);\n    color: var(--sidebar-text);\n    display: flex;\n    flex-direction: column;\n    z-index: 1035;\n    overflow-y: auto;\n    transition: transform 0.3s ease;\n}\n\n.sidebar-brand {\n    padding: 1rem 1.25rem;\n    border-bottom: 1px solid rgba(255,255,255,0.1);\n}\n\n.sidebar-nav {\n    overflow-y: auto;\n    padding: 0.5rem 0;\n}\n\n.sidebar-section {\n    display: block;\n    padding: 0.75rem 1.25rem 0.25rem;\n    font-size: 0.7rem;\n    font-weight: 600;\n    text-transform: uppercase;\n    letter-spacing: 0.05em;\n    color: rgba(255,255,255,0.4);\n}\n\n.sidebar-link {\n    color: var(--sidebar-text);\n    padding: 0.5rem 1.25rem;\n    border-radius: 0;\n    transition: background-color 0.15s;\n}\n\n.sidebar-link:hover,\n.sidebar-link:focus {\n    background: var(--sidebar-hover-bg);\n    color: #fff;\n}\n\n.sidebar-link.active {\n    background: var(--sidebar-active-bg);\n    color: #fff;\n    font-weight: 500;\n}\n\n.sidebar-footer {\n    border-top: 1px solid rgba(255,255,255,0.1);\n    padding: 0.75rem 1.25rem;\n    margin-top: auto;\n}\n\n.mobile-header {\n    position: fixed;\n    top: 0;\n    left: 0;\n    right: 0;\n    height: 3.5rem;\n    background: var(--sidebar-bg);\n    color: #fff;\n    display: flex;\n    align-items: center;\n    padding: 0 1rem;\n    z-index: 1030;\n    gap: 0.75rem;\n}\n\n.sidebar-overlay {\n    position: fixed;\n    inset: 0;\n    background: rgba(0,0,0,0.5);\n    z-index: 1034;\n    display: none;\n}\n\n.main-content {\n    margin-left: var(--sidebar-width);\n    flex: 1;\n    padding: 1rem 1.5rem 2rem;\n    min-width: 0;\n    display: flex;\n    flex-direction: column;\n}\n\n@media (max-width: 767.98px) {\n    .sidebar {\n        transform: translateX(-100%);\n    }\n\n    .sidebar.open {\n        transform: translateX(0);\n    }\n\n    .sidebar-overlay.show {\n        display: block;\n    }\n\n    .main-content {\n        margin-left: 0;\n        margin-top: 3.5rem;\n        padding: 0.75rem;\n    }\n}\n\noption.admin {\n    font-weight: bold;\n    color: var(--color-admin-option);\n}\n\noption:checked {\n    background: var(--color-option-checked);\n}\n\nfooter {\n    text-align: center;\n    color: var(--color-footer-text);\n    border-radius: 8px;\n    background: var(--color-footer-bg);\n    padding: 1em;\n    width: 100%;\n    margin-top: auto;\n    font-weight: 300;\n}\n\nfooter a {\n    color: var(--color-footer-link);\n    font-weight: bold;\n}\n\n[data-bs-theme=\"dark\"] footer {\n    background: #1a1a1a;\n    color: #aaa;\n}\n\n[data-bs-theme=\"dark\"] .logo-light { display: none !important; }\n[data-bs-theme=\"dark\"] .logo-dark { display: inline !important; }\n\n.was-validated .form-control:valid,\n.was-validated .form-select:valid {\n    border-color: var(--bs-border-color);\n    background-image: none;\n}\n.was-validated .form-check-input:valid {\n    border-color: var(--bs-border-color);\n}\n.was-validated .form-check-input:valid:checked {\n    background-color: var(--bs-primary, #0d6efd);\n    border-color: var(--bs-primary, #0d6efd);\n}\n.was-validated .form-check-input:valid ~ .form-check-label {\n    color: inherit;\n}\n\n[data-bs-theme=\"dark\"] footer a {\n    color: #8ab4f8;\n}\n\n[data-bs-theme=\"dark\"] {\n    --choices-bg-color: #2b2b2b;\n    --choices-bg-color-dropdown: #333;\n    --choices-bg-color-disabled: #1a1a1a;\n    --choices-highlighted-color: #444;\n    --choices-primary-color: #4d94ff;\n    --color-footer-bg: #1a1a1a;\n}\n\n.cf {\n    display: flow-root;\n}\n\ndiv.sizes_box {\n    display: flex;\n    align-items: center;\n    justify-content: center;\n    max-width: 10em;\n    padding: 0.3em;\n    gap: 0.5em;\n}\n\n.sizes_box input {\n    max-width: 3em;\n}\n\n.fake_screen {\n    position: relative;\n    background-color: var(--color-fake-screen-bg);\n    width: 100%;\n    background-size: cover;\n    margin: auto;\n    min-height: 200px;\n}\n\n.fake_zone {\n    position: absolute;\n    border: 1px dashed var(--color-fake-zone-border);\n    color: var(--color-fake-zone-border);\n    display: flex;\n    align-items: center;\n    justify-content: center;\n    touch-action: none;\n    user-select: none;\n    transition: background 0.2s;\n}\n\n.fake_zone:hover {\n    background: rgba(255, 255, 255, 0.08);\n}\n\n.fake_zone.selected {\n    border: 2px solid rgba(100, 200, 255, 0.8);\n    background: rgba(100, 200, 255, 0.2);\n    z-index: 2;\n}\n\n.zone-editor-card {\n    cursor: pointer;\n    transition: border-color 0.2s;\n}\n\n.zone-editor-card:hover {\n    border-color: var(--bs-primary);\n}\n\ninput.third {\n    max-width: 28%;\n}\n\n/***************************************/\n\n.published {\n    font-weight: bold;\n}\n\n.unpublished {\n    font-weight: normal;\n    font-style: italic;\n    opacity: 0.6;\n}\n\n.published .onlyunpublished {\n    display: none;\n}\n\n.unpublished .onlypublished {\n    display: none;\n}\n\n.time_future, .time_future a {\n    color: var(--color-time-future);\n}\n\n.time_now {\n    background-color: var(--color-time-now-bg);\n}\n\ntr.time_now:nth-child(odd) {\n    background-color: var(--color-time-now-alt-bg);\n}\n\n.time_past, .time_past a {\n    color: var(--color-time-past);\n    font-style: italic;\n}\n\n.breadcrumb {\n    flex-wrap: wrap;\n    white-space: normal;\n}\n\n.breadcrumb-item {\n    white-space: nowrap;\n}\n\n.clickable-row {\n    cursor: pointer;\n}\n\n.clickable-row:hover {\n    background-color: rgba(0, 0, 0, 0.04) !important;\n}\n\n[data-bs-theme=\"dark\"] .clickable-row:hover {\n    background-color: rgba(255, 255, 255, 0.05) !important;\n}\n\n.skeleton {\n    background: linear-gradient(90deg, rgba(0,0,0,0.06) 25%, rgba(0,0,0,0.1) 50%, rgba(0,0,0,0.06) 75%);\n    background-size: 200% 100%;\n    animation: skeleton-shimmer 1.5s ease-in-out infinite;\n    border-radius: 4px;\n}\n\n[data-bs-theme=\"dark\"] .skeleton {\n    background: linear-gradient(90deg, rgba(255,255,255,0.06) 25%, rgba(255,255,255,0.1) 50%, rgba(255,255,255,0.06) 75%);\n    background-size: 200% 100%;\n}\n\n.skeleton-text {\n    height: 1em;\n    margin-bottom: 0.5em;\n}\n\n.skeleton-text-sm {\n    height: 0.75em;\n    width: 60%;\n}\n\n.skeleton-btn {\n    height: 2.25em;\n    width: 5em;\n}\n\n@keyframes skeleton-shimmer {\n    0% { background-position: 200% 0; }\n    100% { background-position: -200% 0; }\n}\n\n.post-thumbnail {\n    max-height: 2.5em;\n    max-width: 4em;\n    vertical-align: middle;\n    border-radius: 0.25em;\n    object-fit: cover;\n}\n}\n"
